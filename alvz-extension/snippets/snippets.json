    "Esperar (Sleep)": {
        "prefix": "esperar",
        "body": [
            "esperar(${1:1})",
            "imprimir(\"Espera de \" + ${1:1} + \" segundo completada\")"
        ],
        "description": "Pausa la ejecución por N segundos"
    },
    "Validar Email": {
        "prefix": "validaremail",
        "body": [
            "funcion validar_email(email) {",
            "\tvariable partes = dividir(email, \"@\")",
            "\tsi longitud(partes) != 2 { retornar falso }",
            "\tvariable dominio = partes[1]",
            "\tvariable tiene_punto = regex_buscar(dominio, \"\\\\.\")",
            "\tretornar longitud(tiene_punto) > 0",
            "}",
            "",
            "variable email = \"${1:usuario@ejemplo.com}\"",
            "si validar_email(email) {",
            "\timprimir(\"Email valido\")",
            "} sino {",
            "\timprimir(\"Email invalido\")",
            "}"
        ],
        "description": "Valida un formato de email"
    },
    "Validar Campos Requeridos": {
        "prefix": "validarreq",
        "body": [
            "funcion campos_requeridos(datos, campos) {",
            "\tcada campo en campos {",
            "\t\tsi datos[campo] == nulo o datos[campo] == \"\" {",
            "\t\t\tretornar falso",
            "\t\t}",
            "\t}",
            "\tretornar verdadero",
            "}",
            "",
            "variable datos = ${1:input}",
            "variable campos = ${2:[\"nombre\", \"email\"]}",
            "si campos_requeridos(datos, campos) {",
            "\timprimir(\"Todos los campos requeridos estan presentes\")",
            "} sino {",
            "\timprimir(\"Faltan campos requeridos\")",
            "}"
        ],
        "description": "Valida que campos requeridos no estén vacíos"
    },
    "Manejo de Errores": {
