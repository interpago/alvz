        ],
        "description": "Lanza un error personalizado"
    },
    "Dividir Texto": {
        "prefix": "dividir",
        "body": [
            "variable partes = dividir(\"${1:texto}\", \"${2:,}\")",
            "cada parte en partes {",
            "\timprimir(parte)",
            "}"
        ],
