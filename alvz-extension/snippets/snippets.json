            "",
            "funcion main() {",
            "\timprimir(\"${1:Aplicacion iniciada}\")",
            "\t$0",
            "}",
            "",
            "main()"
        ],
        "description": "Estructura base de un script Alvz con imports estándar"
    },
    "Leer Entrada de Usuario": {
