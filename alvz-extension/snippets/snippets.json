    },
    "Unir Lista": {
        "prefix": "unir",
        "body": [
            "variable lista = ${1:[\"a\", \"b\", \"c\"]}",
            "variable texto = unir(lista, \"${2:, }\")",
            "imprimir(texto)"
        ],
        "description": "Une los elementos de una lista con un separador"
    },
    "Buscar con Regex": {
        "prefix": "regex",
        "body": [
            "variable coincidencias = regex_buscar(\"${1:texto}\", \"${2:patron}\")",
            "imprimir(\"Coincidencias encontradas: \" + longitud(coincidencias))",
            "cada c en coincidencias {",
            "\timprimir(c)",
            "}"
        ],
        "description": "Busca patrones en un texto usando expresiones regulares"
    },
    "Menú Interactivo": {
        "prefix": "menu",
        "body": [
            "funcion mostrar_menu() {",
            "\timprimir(\"${1:=== MENU PRINCIPAL ===}\")",
            "\timprimir(\"${2:1}. Opcion 1\")",
            "\timprimir(\"${3:2}. Opcion 2\")",
            "\timprimir(\"${4:3}. Salir\")",
            "}",
            "",
            "variable opcion = 0",
            "mientras opcion != ${4:3} {",
            "\tmostrar_menu()",
            "\topcion = leer_numero()",
            "\tsi opcion == ${2:1} {",
            "\t\timprimir(\"Elegiste opcion 1\")",
            "\t} sino si opcion == ${3:2} {",
            "\t\timprimir(\"Elegiste opcion 2\")",
            "\t} sino si opcion == ${4:3} {",
            "\t\timprimir(\"Hasta luego\")",
            "\t} sino {",
            "\t\timprimir(\"Opcion invalida\")",
            "\t}",
            "}"
        ],
        "description": "Crea un menú interactivo por consola"
    },
    "Configuración desde Variables": {
        "prefix": "config",
        "body": [
            "variable CONFIG = {",
            "\t\"${1:puerto}\": ${2:8000},",
            "\t\"${3:debug}\": ${4:verdadero},",
            "\t\"${5:base_url}\": \"${6:http://localhost}\"",
            "}",
            "",
            "funcion obtener_config(clave) {",
            "\tsi CONFIG[clave] != nulo {",
            "\t\tretornar CONFIG[clave]",
            "\t}",
            "\tretornar nulo",
            "}"
        ],
        "description": "Define configuración global con acceso tipado"
    },
    "CRUD Completo": {
        "prefix": "crud",
        "body": [
            "variable items = []",
            "",
            "funcion crear(id, nombre) {",
            "\tagregar(items, {\"id\": id, \"nombre\": nombre})",
            "\timprimir(\"Item creado: \" + nombre)",
            "}",
            "",
            "funcion listar() {",
            "\tcada item en items {",
            "\t\timprimir(item[\"id\"] + \": \" + item[\"nombre\"])",
            "\t}",
            "}",
            "",
            "funcion actualizar(id, nuevo_nombre) {",
            "\tvariable i = 0",
            "\tmientras i < longitud(items) {",
            "\t\tsi items[i][\"id\"] == id {",
            "\t\t\titems[i][\"nombre\"] = nuevo_nombre",
            "\t\t\timprimir(\"Item \" + id + \" actualizado\")",
            "\t\t\tretornar",
            "\t\t}",
            "\t\ti = i + 1",
            "\t}",
            "\timprimir(\"Item \" + id + \" no encontrado\")",
            "}",
            "",
            "funcion eliminar(id) {",
            "\tvariable nueva_lista = []",
            "\tcada item en items {",
            "\t\tsi item[\"id\"] != id {",
            "\t\t\tagregar(nueva_lista, item)",
            "\t\t}",
            "\t}",
            "\titems = nueva_lista",
            "\timprimir(\"Item \" + id + \" eliminado\")",
            "}"
        ],
        "description": "CRUD completo en memoria con crear, listar, actualizar, eliminar"
    },
    "Pagina Web HTML": {
        "prefix": "pagina",
        "body": [
            "funcion generar_html(titulo, contenido) {",
            "\tvariable html = \"<!DOCTYPE html>\"",
            "\thtml = html + \"<html><head><title>\" + titulo + \"</title></head>\"",
            "\thtml = html + \"<body><h1>\" + titulo + \"</h1>\"",
            "\thtml = html + \"<p>\" + contenido + \"</p></body></html>\"",
            "\tretornar html",
            "}",
            "",
            "variable html = generar_html(\"${1:Mi Pagina}\", \"${2:Hola Mundo}\")",
            "escribir_archivo(\"${3:index.html}\", html)",
            "imprimir(\"Pagina creada: ${3:index.html}\")"
        ],
        "description": "Genera una página HTML y la guarda en un archivo"
    },
    "Generar API desde Archivo JSON": {
        "prefix": "apijson",
        "body": [
            "funcion ${1:cargar_datos}() {",
            "\tvariable datos = leer_archivo(\"${2:datos.json}\")",
            "\tsi datos == falso { retornar [] }",
            "\tretornar json_decodificar(datos)",
            "}",
            "",
            "funcion ${3:guardar_datos}(datos) {",
            "\tescribir_archivo(\"${2:datos.json}\", json_codificar(datos))",
            "}",
            "",
            "funcion ${4:obtener_lista}() {",
 "\tretornar ${1:cargar_datos}()",
            "}",
            "",
            "funcion ${5:agregar_item}(nuevo) {",
            "\tvariable lista = ${1:cargar_datos}()",
            "\tagregar(lista, nuevo)",
            "\t${3:guardar_datos}(lista)",
            "\tretornar {\"exito\": verdadero}",
            "}",
            "",
            "variable rutas = {",
            "\t\"/api/items\": \"${4:obtener_lista}\",",
            "\t\"/api/items\": {",
            "\t\t\"funcion\": \"${5:agregar_item}\",",
            "\t\t\"metodo\": \"POST\"",
            "\t}",
            "}",
            "iniciar_servidor(${6:8000}, rutas)"
        ],
        "description": "API REST con persistencia en archivo JSON"
    },
    "Clase Persona (Ejemplo POO)": {
        "prefix": "persona",
        "body": [
            "clase ${1:Persona} {",
            "\tfuncion inicializar(nombre, edad) {",
            "\t\tself.nombre = nombre",
            "\t\tself.edad = edad",
            "\t}",
            "",
            "\tfuncion saludar() {",
            "\t\tretornar \"Hola, soy \" + self.nombre",
            "\t}",
            "",
            "\tfuncion es_mayor_edad() {",
            "\t\tretornar self.edad >= 18",
            "\t}",
            "}",
            "",
            "variable p = nuevo ${1:Persona}(\"${2:Juan}\", ${3:25})",
            "imprimir(p.saludar())",
            "si p.es_mayor_edad() {",
            "\timprimir(\"Es mayor de edad\")",
            "}"
        ],
        "description": "Ejemplo completo de clase Persona con POO"
    },
    "Filtrar Lista": {
        "prefix": "filtrar",
        "body": [
            "funcion filtrar(lista, condicion) {",
            "\tvariable resultado = []",
            "\tcada item en lista {",
            "\t\tsi condicion(item) {",
            "\t\t\tagregar(resultado, item)",
            "\t\t}",
            "\t}",
            "\tretornar resultado",
            "}",
            "",
            "variable numeros = ${1:[1, 2, 3, 4, 5, 6]}",
            "variable pares = filtrar(numeros, funcion(n) { retornar n % 2 == 0 })",
            "imprimir(pares)"
        ],
        "description": "Filtra elementos de una lista usando una función condición"
    },
    "Mapear Lista": {
        "prefix": "mapear",
        "body": [
            "funcion mapear(lista, transformacion) {",
            "\tvariable resultado = []",
            "\tcada item en lista {",
            "\t\tagregar(resultado, transformacion(item))",
            "\t}",
            "\tretornar resultado",
            "}",
            "",
            "variable numeros = ${1:[1, 2, 3, 4, 5]}",
            "variable dobles = mapear(numeros, funcion(n) { retornar n * 2 })",
            "imprimir(dobles)"
        ],
        "description": "Transforma cada elemento de una lista usando una función"
    },
    "Contar coincidencias en texto": {
        "prefix": "contar",
        "body": [
            "funcion contar_coincidencias(texto, palabra) {",
            "\tvariable partes = dividir(texto, \" \")",
            "\tvariable contador = 0",
            "\tcada p en partes {",
            "\t\tsi p == palabra {",
            "\t\t\tcontador = contador + 1",
            "\t\t}",
            "\t}",
            "\tretornar contador",
            "}",
            "",
            "variable texto = \"${1:el gato y el perro y el pajaro}\"",
            "variable conteo = contar_coincidencias(texto, \"${2:el}\")",
            "imprimir(\"Coincidencias: \" + conteo)"
        ],
        "description": "Cuenta cuántas veces aparece una palabra en un texto"
    },
    "Ordenar Lista": {
        "prefix": "ordenar",
        "body": [
            "funcion ordenar(lista) {",
            "\tvariable n = longitud(lista)",
            "\tvariable i = 0",
            "\tmientras i < n {",
            "\t\tvariable j = 0",
            "\t\tmientras j < n - i - 1 {",
            "\t\t\tsi lista[j] > lista[j + 1] {",
            "\t\t\t\tvariable temp = lista[j]",
            "\t\t\t\tlista[j] = lista[j + 1]",
            "\t\t\t\tlista[j + 1] = temp",
            "\t\t\t}",
            "\t\t\tj = j + 1",
            "\t\t}",
            "\t\ti = i + 1",
            "\t}",
            "\tretornar lista",
            "}",
            "",
            "variable numeros = ${1:[3, 1, 4, 1, 5, 9]}",
            "imprimir(ordenar(numeros))"
        ],
        "description": "Ordena una lista numérica usando el algoritmo de burbuja"
    },
    "Función con tipo de retorno": {
        "prefix": "funciont",
        "body": [
            "funcion ${1:nombre}(${2:parametros}): ${3:texto} {",
            "\t$0",
            "}"
        ],
        "description": "Crea una función con tipo de retorno anotado"
    },
    "Variable con tipo": {
        "prefix": "variablet",
        "body": [
            "variable ${1:nombre}: ${2:numero} = ${3:valor}"
        ],
        "description": "Declara una variable con tipo estático"
    },
    "Generar API CRUD desde Supabase": {
        "prefix": "supacrud",
        "body": [
            "variable SU_URL = \"${1:https://proyecto.supabase.co}\"",
            "variable SU_KEY = \"${2:api-key}\"",
            "variable TABLA = \"${3:items}\"",
            "",
            "funcion listar_items() {",
            "\tvariable url = SU_URL + \"/rest/v1/\" + TABLA",
            "\t# Simula consulta get",
            "\tretornar {\"items\": []}",
            "}",
            "",
            "funcion crear_item(datos) {",
            "\tvariable codigo = supabase_insertar(SU_URL, SU_KEY, TABLA, datos)",
            "\tsi codigo == 201 {",
            "\t\tretornar {\"exito\": verdadero, \"codigo\": codigo}",
            "\t}",
            "\tretornar {\"exito\": falso, \"codigo\": codigo}",
            "}",
            "",
            "variable rutas = {",
            "\t\"/api/items\": \"listar_items\",",
            "\t\"/api/items\": {\"funcion\": \"crear_item\", \"metodo\": \"POST\"}",
            "}",
            "iniciar_servidor(${4:8000}, rutas)"
        ],
        "description": "API CRUD conectada a Supabase"
    },
    "Script de base": {
        "prefix": "base",
