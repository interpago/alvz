{
    "Definir Función": {
        "prefix": "funcion",
        "body": [
            "funcion ${1:nombre}(${2:parametros}) {",
            "\t$0",
            "}"
        ],
        "description": "Crea una nueva función"
    },
    "Condicional Si": {
        "prefix": "si",
        "body": [
            "si ${1:condicion} {",
            "\t$0",
            "}"
        ],
        "description": "Bloque condicional si"
    },
    "Condicional Si-Sino": {
        "prefix": "sino",
        "body": [
            "si ${1:condicion} {",
            "\t$2",
            "} sino {",
            "\t$0",
            "}"
        ],
        "description": "Bloque condicional si con sino"
    },
    "Bucle Mientras": {
        "prefix": "mientras",
        "body": [
            "mientras ${1:condicion} {",
            "\t$0",
            "}"
        ],
        "description": "Bucle mientras"
    },
    "Bucle Para": {
        "prefix": "para",
        "body": [
            "para ${1:variable} de ${2:inicio} a ${3:fin} {",
            "\t$0",
            "}"
        ],
        "description": "Bucle para con rango"
    },
    "Bucle Cada": {
        "prefix": "cada",
        "body": [
            "cada ${1:elemento} en ${2:lista} {",
            "\t$0",
            "}"
        ],
        "description": "Bucle para cada elemento en lista"
    },
    "Definir Clase": {
        "prefix": "clase",
        "body": [
            "clase ${1:NombreClase} {",
            "\tfuncion inicializar(${2:parametros}) {",
            "\t\t$0",
            "\t}",
            "}"
        ],
        "description": "Crea una nueva clase con constructor"
    },
    "Clase con Herencia": {
        "prefix": "claseh",
        "body": [
            "clase ${1:Hija} de ${2:Padre} {",
            "\tfuncion inicializar(${3:parametros}) {",
            "\t\tsuper.${2:Padre}.inicializar(${4:args_padre})",
            "\t\t$0",
            "\t}",
            "",
            "\tfuncion ${5:metodo_nuevo}() {",
            "\t\t$6",
            "\t}",
            "}"
        ],
        "description": "Crea una clase con herencia"
    },
    "Propiedad Getter/Setter": {
        "prefix": "propiedad",
        "body": [
            "propiedad ${1:nombre} {",
            "\tobtener {",
            "\t\tretornar ${2:valor_privado}",
            "\t}",
            "\testablecer(${3:valor}) {",
            "\t\t${2:valor_privado} = ${3:valor}",
            "\t}",
            "}"
        ],
        "description": "Define una propiedad con getter y setter"
    },
    "Método Estático": {
        "prefix": "estatico",
        "body": [
            "funcion estatico ${1:nombre}(${2:args}) {",
            "\t$0",
            "}"
        ],
        "description": "Define un método estático"
    },
    "Imprimir en Consola": {
        "prefix": "imprimir",
        "body": [
            "imprimir(${1:mensaje})"
        ],
        "description": "Imprime un mensaje en la terminal"
    },
    "Iniciar Servidor API": {
        "prefix": "servidor",
        "body": [
            "funcion ${1:ruta_inicio}() {",
            "\tretornar {\"mensaje\": \"${2:API funcionando}\"}",
            "}",
            "",
            "variable rutas = {",
            "\t\"/\": \"${1:ruta_inicio}\"",
            "}",
            "iniciar_servidor(${3:8000}, rutas)"
        ],
        "description": "Configura e inicia un servidor FastAPI"
    },
    "API con múltiples rutas": {
        "prefix": "api",
        "body": [
            "funcion ${1:inicio}() {",
            "\tretornar {\"mensaje\": \"Bienvenido\"}",
            "}",
            "",
            "funcion ${2:obtener_item}(id) {",
            "\tretornar {\"id\": id, \"nombre\": \"Item \" + id}",
            "}",
            "",
            "funcion ${3:crear_item}(datos) {",
            "\tretornar {\"creado\": verdadero, \"datos\": datos}",
            "}",
            "",
            "variable rutas = {",
            "\t\"/\": \"${1:inicio}\",",
            "\t\"/items/{id}\": \"${2:obtener_item}\",",
            "\t\"/items\": {",
            "\t\t\"funcion\": \"${3:crear_item}\",",
            "\t\t\"metodo\": \"POST\"",
            "\t}",
            "}",
            "iniciar_servidor(${4:8000}, rutas)"
        ],
        "description": "Crea una API REST completa con GET y POST"
    },
    "Conexión Supabase": {
        "prefix": "supabase",
        "body": [
            "variable SUPABASE_URL = \"${1:https://tu-proyecto.supabase.co}\"",
            "variable SUPABASE_KEY = \"${2:tu-api-key}\"",
            "variable TABLA = \"${3:nombre_tabla}\"",
            "",
            "funcion listar() {",
            "\timprimir(\"Listando datos de \" + TABLA)",
            "\t$0",
            "}"
        ],
        "description": "Configura conexión a Supabase"
    },
    "Supabase Insertar": {
        "prefix": "supainsert",
        "body": [
            "variable datos = {",
            "\t\"${1:columna}\": ${2:valor}",
            "}",
            "variable codigo = supabase_insertar(SUPABASE_URL, SUPABASE_KEY, \"${3:tabla}\", datos)",
            "si codigo == 201 {",
            "\timprimir(\"Insertado correctamente\")",
            "} sino {",
            "\timprimir(\"Error al insertar: \" + codigo)",
            "}"
        ],
        "description": "Inserta datos en Supabase"
    },
    "Importar Archivo": {
        "prefix": "importar",
        "body": [
            "importar \"${1:archivo}.alvz\""
        ],
        "description": "Importa otro archivo Alvz"
    },
    "Función Async": {
        "prefix": "async",
        "body": [
            "funcion async ${1:nombre}(${2:parametros}) {",
            "\t$0",
            "}"
        ],
        "description": "Crea una nueva función asíncrona"
    },
    "Aguardar": {
        "prefix": "aguardar",
        "body": [
            "aguardar ${1:funcion}(${2:args})"
        ],
        "description": "Espera la ejecución de una función asíncrona"
    },
    "Async Paralelo": {
        "prefix": "asyncpar",
        "body": [
            "funcion async ${1:tarea_a}() {",
            "\timprimir(\"Inicia tarea A\")",
            "\tesperar(${2:1})",
            "\timprimir(\"Termina tarea A\")",
            "\tretornar \"Resultado A\"",
            "}",
            "",
            "funcion async ${3:tarea_b}() {",
            "\timprimir(\"Inicia tarea B\")",
            "\tesperar(${4:0.5})",
            "\timprimir(\"Termina tarea B\")",
            "\tretornar \"Resultado B\"",
            "}",
            "",
            "funcion async ${5:main}() {",
            "\tvariable a = aguardar ${1:tarea_a}()",
            "\tvariable b = aguardar ${3:tarea_b}()",
            "\timprimir(\"Completado: \" + a + \" - \" + b)",
            "}",
            "",
            "aguardar ${5:main}()"
        ],
        "description": "Ejecuta múltiples funciones async en paralelo"
    },
    "Leer Archivo": {
        "prefix": "leerarchivo",
        "body": [
            "variable contenido = leer_archivo(\"${1:archivo.txt}\")",
            "si contenido == falso {",
            "\timprimir(\"Error: No se pudo leer el archivo\")",
            "} sino {",
            "\timprimir(contenido)",
            "}"
        ],
        "description": "Lee el contenido de un archivo"
    },
    "Escribir Archivo": {
        "prefix": "escribirarchivo",
        "body": [
            "variable exito = escribir_archivo(\"${1:archivo.txt}\", ${2:contenido})",
            "si exito {",
            "\timprimir(\"Archivo guardado correctamente\")",
            "} sino {",
            "\timprimir(\"Error al guardar el archivo\")",
            "}"
        ],
        "description": "Escribe contenido en un archivo"
    },
    "JSON Codificar": {
