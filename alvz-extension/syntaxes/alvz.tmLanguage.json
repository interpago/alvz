{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Alvz",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#builtins"
        },
        {
            "include": "#constants"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#function-call"
        },
        {
            "include": "#property-access"
        },
        {
            "include": "#operators"
        }
    ],
    "repository": {
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.alvz",
                    "match": "\\b(si|sino|mientras|para|cada|retornar|intentar|capturar|lanzar|importar|aguardar)\\b"
                },
                {
                    "name": "keyword.operator.word.alvz",
                    "match": "\\b(de|a|en|async)\\b"
                },
                {
                    "name": "keyword.other.alvz",
                    "match": "\\b(variable|funcion|clase|nuevo|estatico)\\b"
                }
            ]
        },
        "builtins": {
            "patterns": [
                {
                    "name": "support.function.alvz",
                    "match": "\\b(imprimir|leer|leer_numero|azar|limpiar|longitud|agregar|esperar|enviar_web|escribir_archivo|minusculas|mayusculas|obtener_salida|supabase_insertar|leer_archivo|supabase_consultar|json_decodificar|json_codificar|tiempo|tipo|reemplazar|absoluto|redondear|potencia|raiz|error_msj|iniciar_servidor)\\b"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.language.alvz",
                    "match": "\\b(verdadero|falso|nulo)\\b"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.alvz",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.alvz",
                            "match": "\\\\."
                        }
                    ]
                },
                {
                    "name": "string.quoted.single.alvz",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        {
                            "name": "constant.character.escape.alvz",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.number-sign.alvz",
                    "match": "#.*"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.alvz",
                    "match": "\\b\\d+(\\.\\d+)?\\b"
                }
            ]
        },
        "function-call": {
            "patterns": [
                {
                    "name": "support.function.alvz",
                    "match": "\\b(imprimir|leer|leer_numero|azar|limpiar|longitud|agregar|esperar|enviar_web|escribir_archivo|minusculas|mayusculas|obtener_salida|supabase_insertar|leer_archivo|supabase_consultar|json_decodificar|json_codificar|tiempo|tipo|reemplazar|absoluto|redondear|potencia|raiz|error_msj|iniciar_servidor)\\s*(?=\\()",
                    "captures": {
                        "1": { "name": "support.function.alvz" }
                    }
                },
                {
                    "match": "(\\b(funcion)\\b)\\s+(async)\\s+([a-zA-Z_]\\w*)",
                    "captures": {
                        "1": { "name": "keyword.other.alvz" },
                        "2": { "name": "keyword.other.alvz" },
                        "3": { "name": "keyword.operator.word.alvz" },
                        "4": { "name": "entity.name.function.alvz" }
                    }
                },
                {
                    "match": "(\\b(funcion)\\b)\\s+([a-zA-Z_]\\w*)",
                    "captures": {
                        "1": { "name": "keyword.other.alvz" },
                        "3": { "name": "entity.name.function.alvz" }
                    }
                },
                {
                    "match": "(\\b(funcion)\\b)\\s+(estatico)\\s+([a-zA-Z_]\\w*)",
                    "captures": {
                        "1": { "name": "keyword.other.alvz" },
                        "2": { "name": "keyword.other.alvz" },
                        "3": { "name": "keyword.other.alvz" },
                        "4": { "name": "entity.name.function.alvz" }
                    }
                },
                {
                    "match": "(\\b(clase)\\b)\\s+([a-zA-Z_]\\w*)",
                    "captures": {
                        "1": { "name": "keyword.other.alvz" },
                        "3": { "name": "entity.name.type.class.alvz" }
                    }
                },
                {
                    "match": "\\b([a-zA-Z_]\\w*)\\s*(?=\\()",
                    "captures": {
                        "1": { "name": "entity.name.function.call.alvz" }
                    }
                }
            ]
        },
        "property-access": {
            "patterns": [
                {
                    "match": "([a-zA-Z_]\\w*)\\s*(\\.)\\s*([a-zA-Z_]\\w*)",
                    "captures": {
                        "1": { "name": "variable.other.alvz" },
                        "2": { "name": "punctuator.dot.alvz" },
                        "3": { "name": "variable.other.property.alvz" }
                    }
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.logical.alvz",
                    "match": "\\b(y|o)\\b"
                },
                {
                    "name": "keyword.operator.alvz",
                    "match": "\\+|\\-|\\*|/|%|==|!=|>=|<=|>|<|="
                }
            ]
        }
    },
    "scopeName": "source.alvz"
}
